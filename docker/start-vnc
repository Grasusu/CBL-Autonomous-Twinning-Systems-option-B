#!/usr/bin/env bash
set -euo pipefail

export DISPLAY="${DISPLAY:-:1}"
export VNC_PORT="${VNC_PORT:-5901}"
export VNC_RESOLUTION="${VNC_RESOLUTION:-1280x800}"
export VNC_COL_DEPTH="${VNC_COL_DEPTH:-24}"
export LIBGL_ALWAYS_SOFTWARE="${LIBGL_ALWAYS_SOFTWARE:-1}"

display_number="${DISPLAY#:}"
rm -f "/tmp/.X${display_number}-lock" "/tmp/.X11-unix/X${display_number}" || true
vncserver -kill "${DISPLAY}" >/dev/null 2>&1 || true

vncserver "${DISPLAY}" \
  -geometry "${VNC_RESOLUTION}" \
  -depth "${VNC_COL_DEPTH}" \
  -localhost no \
  -rfbport "${VNC_PORT}"

cat <<EOF
VNC server started.
Connect to 127.0.0.1:${VNC_PORT}
Password: ros
DISPLAY=${DISPLAY}
EOF
